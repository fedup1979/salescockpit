SALES_COCKPIT_DB_PATH=data/sales_cockpit.db
SALES_COCKPIT_STORAGE_PATH=storage
SALES_COCKPIT_ENVIRONMENT=local
SALES_COCKPIT_SEED_PASSWORD=ChangeMe!2026
SALES_COCKPIT_SEED_DEMO_DATA=true

# Required for non-webhook application API endpoints outside local tests.
SALES_COCKPIT_API_TOKEN=

# Required for JSON mock webhook calls outside local tests.
SALES_COCKPIT_MOCK_WEBHOOK_TOKEN=

# Twilio, not required for mock mode.
SALES_COCKPIT_TWILIO_MODE=mock
SALES_COCKPIT_TWILIO_ACCOUNT_SID=
SALES_COCKPIT_TWILIO_AUTH_TOKEN=
SALES_COCKPIT_TWILIO_WHATSAPP_SENDER=
SALES_COCKPIT_TWILIO_MESSAGING_SERVICE_SID=
SALES_COCKPIT_TWILIO_ALLOWED_RECIPIENTS=
SALES_COCKPIT_TWILIO_VALIDATE_SIGNATURE=true
SALES_COCKPIT_TWILIO_WEBHOOK_URL=
SALES_COCKPIT_TWILIO_STATUS_CALLBACK_URL=
SALES_COCKPIT_TWILIO_CONTENT_READ_ONLY=true

# Read-only integrations, not required for mock mode.
SALES_COCKPIT_SCHOOLDRIVE_MCP_URL=
SALES_COCKPIT_SCHOOLDRIVE_WEBHOOK_TOKEN=
SALES_COCKPIT_FRONT_API_TOKEN=
SALES_COCKPIT_FRONT_IMPORT_QUERY=
SALES_COCKPIT_FRONT_IMPORT_INBOX_IDS=
SALES_COCKPIT_NOTION_TOKEN=
